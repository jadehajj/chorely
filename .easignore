# EAS Build archive ignore rules — mirrors .gitignore but omits Firebase config files
# so that GoogleService-Info.plist and google-services.json are included in the upload.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# generated native folders — track ios/ but ignore CocoaPods & build artifacts
/android
ios/Pods/
ios/build/
ios/DerivedData/
